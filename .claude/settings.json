{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh release list:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh auth status:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(pre-commit --version)",
      "Bash(pre-commit install:*)",
      "Bash(pre-commit run:*)",
      "Read(**)",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(gh repo delete:*)",
      "Bash(gh secret set:*)",
      "Bash(gh secret delete:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*secret*)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)"
    ]
  },
  "effortLevel": "xhigh",
  "theme": "auto",
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  }
}
